---
const { title = "Counting Stars" } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: system-ui, sans-serif; color: #222; line-height: 1.6; max-width: 960px; margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 3rem); }
      nav { display: flex; justify-content: space-between; align-items: center; padding: 1.5rem 0; border-bottom: 1px solid #eee; }
      nav a { color: #222; text-decoration: none; margin-left: 1.5rem; }
      nav a:hover { text-decoration: underline; }
      nav a.admin-link { color: #888; font-size: 0.875rem; }
      .site-name { font-weight: 700; font-size: 1.2rem; }
      footer { border-top: 1px solid #eee; padding: 2rem 0; margin-top: 4rem; color: #888; font-size: 0.875rem; }
      main p { margin-bottom: 1em; }
      main h1, main h2, main h3 { margin-top: 1.5em; margin-bottom: 0.5em; }
      main ul, main ol { margin: 0 0 1em 1.5em; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="site-name">Counting Stars</a>
      <div>
        <a href="/product">Product</a>
        <a href="/blog">Blog</a>
        <a href="/story">Our story</a>
        <a href="/admin" class="admin-link">Admin</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; 2026 Counting Stars</p>
    </footer>
  </body>
</html>
