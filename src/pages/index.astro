---
import Base from "../layouts/Base.astro";
import { getEntry } from "astro:content";
const home = await getEntry("pages", "home");
const { Content } = await home.render();
---
<Base title="Counting Stars">
  <section style="padding: 4rem 0; text-align: center;">
    <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">{home.data.headline}</h1>
    <p style="font-size: 1.25rem; color: #666;">{home.data.subheadline}</p>
    <a href="/product" style="display: inline-block; margin-top: 2rem; padding: 0.75rem 2rem; background: #222; color: #fff; text-decoration: none;">View the Deck</a>
  </section>
  <section style="padding: 2rem 0;">
    <Content />
  </section>
  <script is:inline>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("login", function() {
        document.location.href = "/admin/";
      });
    }
  </script>
</Base>
