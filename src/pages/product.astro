---
import Base from "../layouts/Base.astro";
import { getEntry } from "astro:content";
const product = await getEntry("pages", "product");
const { Content } = await product.render();
---
<Base title="The Deck — Counting Stars">
  <section style="padding: 4rem 0;">
    <h1 style="font-size: 2rem; margin-bottom: 0.5rem;">{product.data.headline}</h1>
    <p style="font-size: 1.1rem; color: #666; margin-bottom: 2rem;">{product.data.subheadline}</p>
    <div style="background: #f5f5f5; height: 300px; display: flex; align-items: center; justify-content: center; color: #aaa; margin-bottom: 2rem;">[ Product image placeholder ]</div>
    <p style="margin-bottom: 2rem;">{product.data.body_text}</p>
    <Content />
    <a href="#" style="display: inline-block; margin-top: 2rem; padding: 0.75rem 2rem; background: #222; color: #fff; text-decoration: none;">Buy Now (placeholder)</a>
  </section>
</Base>
